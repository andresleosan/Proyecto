# ==========================================
# Backend - WhatsApp Integration Variables
# ==========================================

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# WhatsApp Business API Credentials
# Obtén estos valores en: https://business.facebook.com/
WHATSAPP_API_TOKEN=your_whatsapp_bearer_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Webhook Configuration
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Server Configuration
PORT=3000
NODE_ENV=development

# ==========================================
# Frontend - AI & API Integration Variables
# ==========================================

# Anthropic Claude API Key
# Obtén tu key en: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key

# Auto Response Configuration
AUTO_RESPONSE_ENABLED=true
AUTO_RESPONSE_MESSAGE=👋 Hola, gracias por tu mensaje. Un administrador te responderá pronto.

# ==========================================
# Frontend - Environment Variables (.env.local en web/)
# ==========================================

# Firebase Web Configuration
# Obtén estos valores en: Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend API URL
VITE_BACKEND_URL=http://localhost:3000
