rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Permite a usuarios autenticados acceder a sus datos
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Conversaciones de WhatsApp - Solo admins autenticados
    match /whatsapp_conversations/{conversationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Mensajes de WhatsApp - Solo admins autenticados
    match /whatsapp_messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Órdenes de WhatsApp - Solo admins autenticados
    match /whatsapp_orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Ventajas adicionales: Crear índices compuestos si es necesario
    // Firestore te alertará si los necesitas
  }
}
